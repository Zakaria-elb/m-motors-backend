generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  ADMIN
  COMMERCIAL
}

enum VehicleStatus {
  A_VENDRE
  EN_LOCATION
  LES_DEUX
  VENDU
  LOUE
}

enum VehicleType {
  ACHAT
  LOCATION
  LES_DEUX
}

enum DossierType {
  ACHAT
  LOCATION
}

enum DossierStatus {
  BROUILLON
  EN_ATTENTE
  EN_REVISION
  VALIDE
  REFUSE
  SIGNE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  phone        String?
  role         Role     @default(CLIENT)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  dossiers  Dossier[]
  histories DossierHistory[]

  @@map("users")
}

model Vehicle {
  id           String        @id @default(uuid())
  brand        String
  model        String
  year         Int
  mileage      Int
  price        Decimal?      @db.Decimal(10, 2)
  monthlyPrice Decimal?      @map("monthly_price") @db.Decimal(10, 2)
  status       VehicleStatus
  type         VehicleType
  description  String?
  imageUrls    String[]      @map("image_urls")
  options      Json? // {assurance: true, entretien: true...}
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  dossiers Dossier[]

  @@map("vehicles")
}

model Dossier {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  vehicleId      String        @map("vehicle_id")
  type           DossierType
  status         DossierStatus @default(BROUILLON)
  monthlyAmount  Decimal?      @map("monthly_amount") @db.Decimal(10, 2)
  durationMonths Int?          @map("duration_months")
  adminComment   String?       @map("admin_comment")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user      User             @relation(fields: [userId], references: [id])
  vehicle   Vehicle          @relation(fields: [vehicleId], references: [id])
  documents Document[]
  history   DossierHistory[]

  @@map("dossiers")
}

model Document {
  id           String   @id @default(uuid())
  dossierId    String   @map("dossier_id")
  originalName String   @map("original_name")
  s3Key        String   @unique @map("s3_key")
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  dossier Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model DossierHistory {
  id        String        @id @default(uuid())
  dossierId String        @map("dossier_id")
  oldStatus DossierStatus @map("old_status")
  newStatus DossierStatus @map("new_status")
  changedBy String        @map("changed_by") // user_id
  comment   String?
  createdAt DateTime      @default(now()) @map("created_at")

  dossier Dossier @relation(fields: [dossierId], references: [id])
  user    User    @relation(fields: [changedBy], references: [id])

  @@map("dossier_history")
}
